# --- Database ---
DATABASE_URL=postgresql+psycopg://fatwad:fatwad@localhost:5432/fatwad

# --- LLM (tiered routing; each tier has a fallback chain in src/agents/graph.py) ---
# ROUTER   -> planner_node       (cheap classification of user intent)
# AGENTIC  -> tool_node          (deterministic compute + structured output)
# SYNTHESIS-> summarize_node     (final streamed answer; uses :online for browsing)
ROUTER_MODEL=openrouter/meta-llama/llama-3.2-3b-instruct:free
AGENTIC_MODEL=openrouter/openai/gpt-4o-mini
SYNTHESIS_MODEL=openrouter/openai/gpt-4o-mini

OPENROUTER_API_KEY=

# Vercel AI Gateway — paid fallback when OpenRouter rate-limits the free tier.
# Get a token at https://vercel.com/dashboard/integrations/ai-gateway. The agent
# walks the chain in src/agents/llm.py and lands on Vercel automatically.
VERCEL_API_KEY=

# --- App ---
FATWAD_USER_ID=user_1
FATWAD_USER_NAME=me
API_URL=http://localhost:8000
